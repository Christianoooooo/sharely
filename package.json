{
  "name": "sharely",
  "version": "1.0.0",
  "description": "Lightweight file manager with ShareX and *NIX support",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "build": "cd client && npm install && npm run build",
    "migrate:user-folders": "node scripts/migrate-uploads-to-user-folders.js",
    "migrate:thumbnails": "node scripts/generate-missing-thumbnails.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build:sidecar && tauri build",
    "build:sidecar": "node scripts/build-sidecar.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-mongo": "^5.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.0",
    "mime-types": "^2.1.35",
    "mongoose": "^8.4.0",
    "multer": "^1.4.5-lts.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@yao-pkg/pkg": "^5.15.0",
    "nodemon": "^3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pkg": {
    "scripts": [
      "app.js",
      "server-entry.js",
      "src/**/*.js"
    ],
    "assets": [
      "client/dist/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-win-x64"
    ],
    "outputPath": "src-tauri/binaries"
  }
}
