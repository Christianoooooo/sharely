<%- include('partials/header', { title: 'Upload' }) %>

<div class="page-header">
  <h1>Upload Files</h1>
</div>

<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

<div class="upload-area" id="dropZone">
  <form method="POST" action="/upload" enctype="multipart/form-data" id="uploadForm">
    <div class="drop-inner">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
      </svg>
      <p>Drag & drop files here, or <label for="fileInput" class="link-label">browse</label></p>
      <p class="muted">Images, GIF, video, code, text, PDF and more</p>
      <input type="file" id="fileInput" name="files" multiple hidden />
    </div>
    <div id="fileList" class="file-list hidden"></div>
    <button type="submit" class="btn-primary" id="submitBtn" disabled>Upload</button>
  </form>
</div>

<div class="sharex-section">
  <h2>ShareX Integration</h2>
  <p>Download the ShareX custom uploader config and import it into ShareX.</p>
  <a href="/api/sharex-config" class="btn-outline" download>Download .sxcu Config</a>
  <p class="muted mt-1">Your API key is embedded in the config. Keep it secret.</p>
</div>

<div class="api-section">
  <h2>API Upload</h2>
  <p>Upload via <code>curl</code> or any HTTP client:</p>
  <pre><code>curl -X POST \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -F "file=@/path/to/file" \
  <%= typeof BASE_URL !== 'undefined' ? BASE_URL : '' %>/api/upload</code></pre>
  <button class="btn-outline" id="regenKeyBtn">Regenerate API Key</button>
  <code id="apiKeyDisplay" class="api-key-display"></code>
</div>

<%- include('partials/footer', {
  extraScript: `<script>
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const fileList = document.getElementById('fileList');
    const submitBtn = document.getElementById('submitBtn');
    let chosenFiles = new DataTransfer();

    fileInput.addEventListener('change', () => { addFiles(fileInput.files); });

    document.querySelector('.link-label').addEventListener('click', () => fileInput.click());

    dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      addFiles(e.dataTransfer.files);
    });

    function addFiles(files) {
      for (const f of files) chosenFiles.items.add(f);
      fileInput.files = chosenFiles.files;
      renderList();
    }

    function renderList() {
      fileList.innerHTML = '';
      if (chosenFiles.files.length === 0) {
        fileList.classList.add('hidden');
        submitBtn.disabled = true;
        return;
      }
      fileList.classList.remove('hidden');
      submitBtn.disabled = false;
      for (let i = 0; i < chosenFiles.files.length; i++) {
        const f = chosenFiles.files[i];
        const row = document.createElement('div');
        row.className = 'file-row';
        row.innerHTML = '<span>' + escHtml(f.name) + ' <small>(' + fmtSize(f.size) + ')</small></span>'
          + '<button type="button" data-idx="' + i + '" class="remove-btn">✕</button>';
        fileList.appendChild(row);
      }
    }

    fileList.addEventListener('click', (e) => {
      if (!e.target.classList.contains('remove-btn')) return;
      const idx = parseInt(e.target.dataset.idx, 10);
      const dt = new DataTransfer();
      for (let i = 0; i < chosenFiles.files.length; i++) {
        if (i !== idx) dt.items.add(chosenFiles.files[i]);
      }
      chosenFiles = dt;
      fileInput.files = chosenFiles.files;
      renderList();
    });

    function fmtSize(b) {
      if (b < 1024) return b + ' B';
      if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
      return (b/1048576).toFixed(1) + ' MB';
    }
    function escHtml(s) {
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // Regen API key
    document.getElementById('regenKeyBtn').addEventListener('click', async () => {
      if (!confirm('Regenerate API key? Existing ShareX configs will stop working.')) return;
      const res = await fetch('/api/regen-key', { method: 'POST' });
      const data = await res.json();
      document.getElementById('apiKeyDisplay').textContent = data.apiKey;
    });
  </script>`
}) %>
