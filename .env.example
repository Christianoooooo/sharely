# Server
PORT=3000

# MongoDB – docker-compose constructs MONGODB_URI from these automatically
MONGO_ROOT_PASSWORD=change-me-root-password
MONGO_APP_USER=appuser
MONGO_APP_PASSWORD=change-me-app-password
MONGO_DB_NAME=sharely

# Session secret (generate a long random string)
SESSION_SECRET=change-me-to-a-long-random-secret

# Base URL for generated share links (no trailing slash)
BASE_URL=http://localhost:3000

# Site name shown in Open Graph embeds (default: sharely)
SITE_NAME=sharely

# Max upload size in MB (default 100)
MAX_FILE_SIZE_MB=100

# Allow public registration (true/false)
# When false, only admins can create new users
ALLOW_REGISTRATION=true

# SMTP – required for email verification and password reset
# Leave SMTP_HOST blank to disable these features
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set to true for port 465 (implicit TLS), false for STARTTLS on 587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
# From address shown in emails (defaults to SMTP_USER if not set)
SMTP_FROM=noreply@example.com
