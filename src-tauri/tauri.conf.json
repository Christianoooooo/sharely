{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sharely",
  "version": "0.1.0",
  "identifier": "com.sharely.app",
  "build": {
    "frontendDist": "https://sharely.christian.pizza/"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Sharely",
        "url": "https://sharely.christian.pizza/",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
